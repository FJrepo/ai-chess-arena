# Released image source for docker-compose.prod.yml
# Set IMAGE_NAMESPACE to your GitHub user or organization.
# Prefer a pinned version tag for predictable upgrades.
IMAGE_NAMESPACE=your-github-user-or-org
IMAGE_TAG=latest

# Host ports exposed by docker-compose.prod.yml
FRONTEND_PORT=4200
BACKEND_PORT=8081

# Runtime secret
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database defaults
DB_NAME=chess_tournament
DB_USER=chess
DB_PASSWORD=change_me_for_real_deployments
